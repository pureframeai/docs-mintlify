{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Pureframe AI API Documentation",
  "theme": "mint",
  "colors": {
    "primary": "#DA5400",
    "light": "#ff985f",
    "dark": "#DA5400"
  },
  "favicon": {
    "light": "/images/favicon-light.svg",
    "dark": "/images/favicon-dark.svg"
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Get API Key",
      "href": "https://pureframe.ai"
    },
    "links": [
      {
        "href": "mailto:support@pureframe.ai",
        "label": "Support"
      }
    ]
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "get-started/overview",
              "get-started/quickstart",
              "get-started/authentication",
              "get-started/api-keys",
              "get-started/key-concepts"
            ]
          },
          {
            "group": "Search",
            "pages": [
              "search/overview",
              "search/text",
              "search/image",
              "search/transcript",
              "search/combined-queries",
              "search/search-a-video",
              "search/search-a-collection",
              "search/search-results",
              "search/exact-timestamps",
              "search/frame-map"
            ]
          },
          {
            "group": "Video Processing",
            "pages": [
              "video-processing/upload-videos",
              "video-processing/processing-lifecycle",
              "video-processing/collections",
              "video-processing/transcripts",
              "video-processing/embeddings",
              "video-processing/metadata",
              "video-processing/processing-status"
            ]
          },
          {
            "group": "Agents",
            "pages": [
              "agents/agent-vision",
              "agents/mcp-overview",
              "agents/connect-an-agent",
              "agents/source-backed-results",
              "agents/agent-security"
            ]
          },
          {
            "group": "Production",
            "pages": [
              "production/webhooks",
              "production/rate-limits",
              "production/errors",
              "production/performance",
              "production/usage-and-billing",
              "production/data-handling",
              "production/security"
            ]
          },
          {
            "group": "Resources",
            "pages": [
              "resources/examples",
              "resources/use-cases",
              "resources/changelog",
              "resources/faq"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "API Reference",
            "openapi": "openapi.json",
            "pages": [
              "api-reference/overview"
            ]
          }
        ]
      },
      {
        "tab": "SDK Reference",
        "groups": [
          {
            "group": "SDKs",
            "pages": [
              "sdks/python-sdk",
              "sdks/javascript-sdk",
              "sdks/mcp-server"
            ]
          }
        ]
      }
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/pureframeai",
      "x": "https://x.com/pureframeai"
    }
  },
  "description": "Explore guides, API docs, and examples for the Pureframe AI API.",
  "logo": {
    "light": "/images/light.svg",
    "dark": "/images/dark.svg"
  },
  "fonts": {
    "family": "DM Sans"
  },
  "markdown": {
    "schema": true
  },
  "seo": {
    "metatags": {
      "title": "Pureframe AI API Documentation",
      "description": "Explore guides, API docs, and examples for the Pureframe AI API.",
      "og:type": "website",
      "og:site_name": "Pureframe AI Documentation",
      "og:title": "Pureframe AI API Documentation",
      "og:description": "Explore guides, API docs, and examples for the Pureframe AI API."
    }
  },
  "background": {
    "decoration": "gradient"
  }
