  "keyFeatures": [
    "Semantic video search by text query or reference image",
    "Timestamped clip retrieval with presigned video and thumbnail URLs",
    "Asynchronous video indexing with job polling",
    "Collections for organizing videos",
    "Multiple search modes: image_first and fusion (Reciprocal Rank Fusion)",
    "Transcript-aware search with scene and video segment modes",
    "Webhooks for real-time processing notifications",
    "AI agent integration with OpenAI-compatible tool schema",
    "FrameMap visual index for collection-level exploration",
    "Read-only and full-access API key permissions"
  ],
